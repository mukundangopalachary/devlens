DEVLENS_DB_URL=sqlite:///devlens.db
DEVLENS_OLLAMA_MODEL=qwen2.5-coder:7b
DEVLENS_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
DEVLENS_VECTOR_BACKEND=qdrant
DEVLENS_QDRANT_PATH=qdrant_storage
DEVLENS_QDRANT_COLLECTION=devlens_knowledge
DEVLENS_PROJECT_ROOT=.
DEVLENS_MAX_FILE_SIZE_KB=512
DEVLENS_ALLOWED_EXTENSIONS=.py
DEVLENS_LLM_TIMEOUT_SECONDS=30
DEVLENS_CACHE_ENABLED=true
DEVLENS_LOG_LEVEL=INFO
