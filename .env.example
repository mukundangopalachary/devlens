# Database
DEVLENS_DB_URL=<sqlite:///absolute/or/relative/path/to/devlens.db>

# Ollama models
DEVLENS_OLLAMA_MODEL=<llama3.2:3b>
DEVLENS_OLLAMA_EMBEDDING_MODEL=<nomic-embed-text>

# Retrieval backend
DEVLENS_VECTOR_BACKEND=<qdrant|sqlite>
DEVLENS_QDRANT_PATH=<qdrant_storage>
DEVLENS_QDRANT_COLLECTION=<devlens_knowledge>

# Project and scanning
DEVLENS_PROJECT_ROOT=<.>
DEVLENS_MAX_FILE_SIZE_KB=<512>
DEVLENS_ALLOWED_EXTENSIONS=<.py>

# LLM runtime controls
DEVLENS_LLM_TIMEOUT_SECONDS=<30>
DEVLENS_OLLAMA_NUM_CTX=<2048>
DEVLENS_OLLAMA_ANALYSIS_NUM_PREDICT=<256>
DEVLENS_OLLAMA_CHAT_NUM_PREDICT=<384>
DEVLENS_OLLAMA_KEEP_ALIVE=<5m>

# Behavior
DEVLENS_CACHE_ENABLED=<true>
DEVLENS_LOG_LEVEL=<INFO>
